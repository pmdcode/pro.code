generator client {
  provider = "prisma-client"
  output   = "../generated/prisma"
}

datasource db {
  provider = "postgresql"
}

model Project {
  id          Int      @id @default(autoincrement())
  title       String
  description String
  image       String
  github      String?
  live        String?
  createdAt   DateTime @default(now())
}